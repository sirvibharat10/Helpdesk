{
  "name": "sahayak-ai",
  "version": "1.0.0",
  "description": "AI-powered HelpDesk/CRM web application",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && tsx watch src/index.ts",
    "dev:frontend": "cd frontend && vite",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && tsc",
    "build:frontend": "cd frontend && vite build",
    "start": "node dist/index.js",
    "db:push": "cd backend && prisma db push",
    "db:migrate": "cd backend && prisma migrate dev",
    "db:studio": "cd backend && prisma studio",
    "lint": "eslint . --ext .ts,.tsx",
    "test:frontend": "cd frontend && npm run test"
  },
  "keywords": [
    "helpdesk",
    "crm",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "backend",
    "frontend",
    "core"
  ]
}
