# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sahayak"

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d

# Node
NODE_ENV=development
PORT=3001

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Email
EMAIL_FROM_NAME=SahaYak Support
SUPPORT_EMAIL=support@sahayak.ai
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@sahayak.ai
NOTIFICATION_EMAIL=admin@sahayak.ai

# Admin
ADMIN_EMAIL=admin@sahayak.ai
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User

# Sentry (optional)
SENTRY_DSN=

# Frontend
VITE_API_URL=/api
